{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "backend.main:app", "--host", "127.0.0.1", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": ".venv/Scripts/python",
      "runtimeArgs": ["-m", "http.server", "3000", "--directory", "frontend/pwa"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
